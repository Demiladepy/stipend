# Frontend + contract reads (copy to .env.local at repo root when app exists)
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_STIPEND_VAULT_ADDRESS=
# Block the vault was deployed at — lets the dashboard recover stipends from chain logs
NEXT_PUBLIC_VAULT_DEPLOY_BLOCK=
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Privy (dashboard.privy.io — create app, enable Email login + embedded wallets)
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Particle (dashboard.particle.network)
NEXT_PUBLIC_PROJECT_ID=
NEXT_PUBLIC_CLIENT_KEY=
NEXT_PUBLIC_APP_ID=

# Set to 0 to hide the build-time debug panel before the demo
NEXT_PUBLIC_SHOW_DEBUG=1

# Agent scene (Phase 4)
# Server-only key for the demo agent wallet (fresh throwaway, needs ~0.0005 ETH on Base for gas)
AGENT_PRIVATE_KEY=
# Where the paid research API receives its money (any address you control)
NEXT_PUBLIC_SERVICE_ADDRESS=
